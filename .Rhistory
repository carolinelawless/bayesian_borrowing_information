source("TEA_functions.R")
params <- seq(0.6, 0.9, length = 20)
M <- 100
B <- 500
lambdas <- 1:10*10
a_theta <- 1
b_theta <- 1
p_eps <- 0.5
TEA_eval_binomial <- function(params, M, B, lambdas, a_theta, b_theta, p_eps){
L <- length(lambdas)
variance <- vector(length = L)
bias <- vector(length = L)
MSE <- vector(length = L)
for(i in 1:length(lambdas)){
lambda <- lambdas[i]
res <- posterior_sim_binomial(params, M, B, lambda, a_theta, b_theta, p_eps)
variance[i] <- var(res$diffs)
bias[i] <- mean(res$diffs - abs(params[length(params)] - params[1]))
MSE[i] <- variance[i] + bias[i]*bias[i]
}
return(list(variance = variance, bias = bias, MSE = MSE))
}
