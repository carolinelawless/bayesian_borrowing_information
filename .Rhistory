M <- 100
B <- 1000
lambda <- 9
params <- seq(0.6, 0.9, length = 20)   # true means per version
mean_theta <- 0.5                          # prior mean
sd_theta   <- 0.5                          # prior sd
sigma      <- 0.5                          # measurement noise
p_eps <- 0.5
