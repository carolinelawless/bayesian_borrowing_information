col1 = "steelblue"
col2 = "darkseagreen4"
model <- "binomial"
lambdas <- 1:50
stat_name <- "bias"
plot_model_comparison(lambdas, get(paste0("tea_",stat_name,"_",model)), get(paste0("naive_",stat_name,"_",model)), stat_name, col1, col2)
stat_name <- "variance"
plot_model_comparison(lambdas, get(paste0("tea_",stat_name,"_",model)), get(paste0("naive_",stat_name,"_",model)), stat_name, col1, col2)
stat_name <- "mse"
plot_model_comparison(lambdas, get(paste0("tea_",stat_name,"_",model)), get(paste0("naive_",stat_name,"_",model)), stat_name, col1, col2)
