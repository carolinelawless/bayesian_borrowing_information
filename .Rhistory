source("functions.R")
params_gradual <- seq(0.6, 0.9, length = 20)   # true means per version
params_abrupt <- c(rep(0.6, 19), 0.9)
params_drift <- c(seq(0.6, 0.9, length = 10), seq(0.9, 0.6, length = 10))
params_stable <- rep(0.7, 20)
plot_true_theta(params_gradual)
plot_true_theta(params_abrupt)
plot_true_theta(params_drift)
plot_true_theta(params_stable)
M <- 100
B <- 1000
lambda <- 9
a_theta <- 1
b_theta <- 1
mean_theta <- 0.5                          # prior mean
sd_theta   <- 0.5                          # prior sd
sigma      <- 0.5                          # measurement noise
p_eps <- 0.5
df <- bind_rows(
{
par <- params_gradual
res <- posterior_sim_binomial(par, M, B, lambda, a_theta, b_theta, p_eps)
summarize_run(res$thetas, res$epsilons, par, "gradual")
},
{
par <- params_abrupt
res <- posterior_sim_binomial(par, M, B, lambda, a_theta, b_theta, p_eps)
summarize_run(res$thetas, res$epsilons, par, "abrupt")
},
{
par <- params_drift
res <- posterior_sim_binomial(par, M, B, lambda, a_theta, b_theta, p_eps)
summarize_run(res$thetas, res$epsilons, par, "drift")
},
{
par <- params_stable
res <- posterior_sim_binomial(par, M, B, lambda, a_theta, b_theta, p_eps)
summarize_run(res$thetas, res$epsilons, par, "stable")
}
)
library(ggplot2)
ggplot(df, aes(x = version)) +
# Theta intervals
geom_errorbar(aes(ymin = theta_q10, ymax = theta_q90),
width = 0.1, color = "black") +
# Theta mean
geom_point(aes(y = theta_mean), color = "black") +
# True theta
geom_point(aes(y = true_theta), color = "blue", alpha = 0.4, size = 2) +
# Epsilon intervals (slightly shifted)
geom_errorbar(aes(x = version - 0.1,
ymin = eps_q10, ymax = eps_q90),
width = 0.1, color = "red") +
# Epsilon mean
geom_point(aes(x = version - 0.1, y = eps_mean),
color = "red", shape = 4) +
facet_wrap(~scenario, nrow = 1) +
labs(x = "Version", y = "θ / ε") +
theme_minimal(base_size = 16)
ggplot(df, aes(x = version)) +
# Theta intervals
geom_errorbar(aes(ymin = theta_q10, ymax = theta_q90,
color = "theta posterior mean"),
width = 0.1) +
# Theta mean
geom_point(aes(y = theta_mean,
color = "theta posterior mean")) +
# True theta
geom_point(aes(y = true_theta,
color = "true theta"),
alpha = 0.4, size = 2) +
# Epsilon intervals
geom_errorbar(aes(x = version - 0.1,
ymin = eps_q10, ymax = eps_q90,
color = "epsilon posterior mean"),
width = 0.1) +
# Epsilon mean
geom_point(aes(x = version - 0.1,
y = eps_mean,
color = "epsilon posterior mean",
shape = "epsilon posterior mean")) +
facet_wrap(~scenario, nrow = 1) +
labs(x = "Version", y = "θ / ε", color = NULL, shape = NULL) +
scale_color_manual(values = c(
"theta posterior mean" = "black",
"true theta" = rgb(0, 0, 1, 0.4),
"epsilon posterior mean" = "red"
)) +
scale_shape_manual(values = c(
"epsilon posterior mean" = 4
)) +
theme_minimal(base_size = 16) +
theme(
legend.position = "bottom"
)
ggplot(df, aes(x = version)) +
# --- Theta CI ---
geom_errorbar(aes(ymin = theta_q10, ymax = theta_q90,
color = "theta"),
width = 0.1) +
# --- Theta mean (CROSS) ---
geom_point(aes(y = theta_mean,
color = "theta",
shape = "theta"),
size = 3) +
# --- True theta (BLUE DOT) ---
geom_point(aes(y = true_theta,
color = "true"),
alpha = 0.6, size = 2) +
# --- Epsilon CI ---
geom_errorbar(aes(x = version - 0.1,
ymin = eps_q10, ymax = eps_q90,
color = "epsilon"),
width = 0.1) +
# --- Epsilon mean (CROSS) ---
geom_point(aes(x = version - 0.1,
y = eps_mean,
color = "epsilon",
shape = "epsilon"),
size = 3) +
facet_wrap(~scenario, nrow = 1) +
labs(x = "Version", y = "θ / ε", color = NULL, shape = NULL) +
scale_color_manual(values = c(
"theta" = "black",
"true" = "blue",
"epsilon" = "red"
)) +
scale_shape_manual(values = c(
"theta" = 4,     # cross
"epsilon" = 4    # cross
)) +
theme_minimal(base_size = 16) +
theme(
legend.position = "bottom"
)
