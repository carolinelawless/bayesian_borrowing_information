ggplot(df, aes(x = version)) +
# --- Theta CI (no legend) ---
geom_errorbar(aes(ymin = theta_q10, ymax = theta_q90),
color = "black", width = 0.1, show.legend = FALSE) +
# --- Epsilon CI (no legend) ---
geom_errorbar(aes(x = version - 0.1,
ymin = eps_q10, ymax = eps_q90),
color = "red", width = 0.1, show.legend = FALSE) +
# --- Theta mean (BLACK CROSS) ---
geom_point(aes(y = theta_mean,
color = "theta",
shape = "theta"),
size = 3) +
# --- Epsilon mean (RED CROSS) ---
geom_point(aes(x = version - 0.1,
y = eps_mean,
color = "epsilon",
shape = "epsilon"),
size = 3) +
# --- True theta (BLUE DOT) ---
geom_point(aes(y = true_theta,
color = "true"),
size = 2, alpha = 0.7) +
facet_wrap(~scenario, nrow = 1) +
labs(x = "Version", y = "θ / ε", color = NULL, shape = NULL) +
# --- COLORS ---
scale_color_manual(
values = c(
"true" = "blue",
"theta" = "black",
"epsilon" = "red"
),
breaks = c("true", "theta", "epsilon"),  # ORDER
labels = c(
"true" = expression("True " * theta),
"theta" = expression("Posterior " * theta),
"epsilon" = expression("Posterior " * epsilon)
)
) +
# --- SHAPES ---
scale_shape_manual(
values = c(
"theta" = 4,    # cross
"epsilon" = 4   # cross
),
breaks = c("theta", "epsilon"),
labels = c(
"theta" = expression("Posterior " * theta),
"epsilon" = expression("Posterior " * epsilon)
)
) +
theme_minimal(base_size = 16) +
theme(legend.position = "bottom")
